{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "App (Vite dev server)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "app",
      "port": 5173
    },
    {
      "name": "Render Worker",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server.mjs"],
      "cwd": "render-worker",
      "port": 8787
    },
    {
      "name": "Static legacy MVP (python)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "4173"],
      "port": 4173
    }
  ]
}
