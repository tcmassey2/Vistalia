# Dependencies
node_modules/
.pnp/
.pnp.js

# Environment files
.env
.env.*
!.env.example

# Expo / React Native
.expo/
.expo-shared/
web-build/

# Build outputs
dist/
build/
out/
.next/
.vercel/
coverage/

# Vite app build output — /app/ is generated by `cd webapp && npm run build`
# during Vercel deploy. Source lives at /webapp/.
/app/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# OS / editor files
.DS_Store
Thumbs.db
.idea/
.vscode/

# Local runtime artifacts
*.local
*.tmp
exports/
generated/

# Large media — keep on disk as local backups, never commit (they stall pushes)
marketing/higgsfield-ads/
Bakeoff Clips/
EstateMotion Test Photos./
*.mp4
*.mov

# TypeScript incremental build cache (auto-generated, machine-specific)
*.tsbuildinfo
marketing/assembled/

# Generated deliverables (decks, models) — keep local, not in source history
/Vistalia-*.pptx
/Vistalia-*.xlsx

# Business/tax documents — never commit (SS-4 carries SSN/EIN)
SS-4*
*.pdf
!docs/**/*.pdf

# Local-only business docs & media — never commit
_local/

# Meta pixel ID is public by design — the webapp build needs it.
!webapp/.env.production
showcase/photosets/**/*.png
