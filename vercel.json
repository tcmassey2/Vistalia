{
  "cleanUrls": true,
  "trailingSlash": false,
  "buildCommand": "node scripts/verify-static-deploy.mjs && cd webapp && npm install --no-audit --no-fund && npm run build",
  "outputDirectory": ".",
  "crons": [
    {
      "path": "/api/cron/trial-reminders",
      "schedule": "0 14 * * *"
    }
  ],
  "functions": {
    "api/import-listing.js": { "maxDuration": 120 },
    "api/create-edit-plan.js": { "maxDuration": 120 }
  },
  "rewrites": [
    {
      "source": "/v/:token",
      "destination": "/v"
    },
    {
      "source": "/demo",
      "destination": "/app/index.html"
    },
    {
      "source": "/demo/:path*",
      "destination": "/app/index.html"
    },
    {
      "source": "/beta",
      "destination": "/app/index.html"
    },
    {
      "source": "/beta/:path*",
      "destination": "/app/index.html"
    },
    {
      "source": "/waitlist",
      "destination": "/app/index.html"
    },
    {
      "source": "/waitlist/:path*",
      "destination": "/app/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), geolocation=(), payment=()"
        }
      ]
    },
    {
      "source": "/app/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/start",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/start.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/signup",
      "destination": "/app/",
      "permanent": false
    },
    {
      "source": "/login",
      "destination": "/app/",
      "permanent": false
    }
  ]
}